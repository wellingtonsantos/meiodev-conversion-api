___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const log = require('logToConsole');
const sendPixel = require('sendPixel');
const makeString = require('makeString');
const encodeUriComponent = require('encodeUriComponent');
const getTimestampMillis = require('getTimestampMillis');
const getUrl = require('getUrl');
const getReferrerUrl = require('getReferrerUrl');
const getCookieValues = require('getCookieValues');
const copyFromWindow = require('copyFromWindow');
const getType = require('getType');
const JSON = require('JSON');
const makeTableMap = require('makeTableMap');
const Object = require('Object');

// ─── Helpers ─────────────────────────────────────────────────────────────────

function isSet(val) {
  return val !== undefined && val !== null && val !== '';
}

function toLowerCase(str) {
  if (!isSet(str)) return undefined;
  return makeString(str).toLowerCase().trim();
}

function buildQueryString(params) {
  var parts = [];
  var keys = Object.keys(params);
  for (var i = 0; i < keys.length; i++) {
    var key = keys[i];
    var val = params[key];
    if (isSet(val)) {
      parts.push(encodeUriComponent(key) + '=' + encodeUriComponent(makeString(val)));
    }
  }
  return parts.join('&');
}

// ─── Event name ───────────────────────────────────────────────────────────────

var eventName = data.eventName === 'customEvent'
  ? data.customEventName
  : data.eventName;

if (!isSet(eventName)) {
  data.gtmOnSuccess();
  return;
}

// ─── Timestamp ────────────────────────────────────────────────────────────────

var eventTime = Math.floor(getTimestampMillis() / 1000);

// ─── Page data ────────────────────────────────────────────────────────────────

var pageUrl  = data.sendPageUrl  ? getUrl() : undefined;
var referrer = data.sendReferrer ? getReferrerUrl() : undefined;
var pageTitle = data.sendPageTitle
  ? copyFromWindow('document.title')
  : undefined;

// ─── Facebook cookies (auto-read if not provided) ─────────────────────────────

var fbc = isSet(data.fbc)
  ? data.fbc
  : (getCookieValues('_fbc')[0] || undefined);

var fbp = isSet(data.fbp)
  ? data.fbp
  : (getCookieValues('_fbp')[0] || undefined);

// ─── User Agent ───────────────────────────────────────────────────────────────

var userAgent = data.sendUserAgent
  ? copyFromWindow('navigator.userAgent')
  : undefined;

// ─── Assemble payload ─────────────────────────────────────────────────────────

var payload = {};

// Event info
payload.event_name  = eventName;
if (data.sendTimestamp) payload.event_time = eventTime;

// Page info
if (isSet(pageUrl))   payload.page_url   = pageUrl;
if (isSet(pageTitle)) payload.page_title  = pageTitle;
if (isSet(referrer))  payload.referrer    = referrer;
if (isSet(userAgent)) payload.user_agent  = userAgent;

// Event data
if (isSet(data.value))           payload.value           = data.value;
if (isSet(data.currency))        payload.currency        = toLowerCase(data.currency);
if (isSet(data.orderId))         payload.order_id        = data.orderId;
if (isSet(data.contentIds))      payload.content_ids     = data.contentIds;
if (isSet(data.contentName))     payload.content_name    = data.contentName;
if (isSet(data.contentCategory)) payload.content_category = data.contentCategory;
if (isSet(data.numItems))        payload.num_items        = data.numItems;
if (isSet(data.searchString))    payload.search_string    = data.searchString;

// User data
var userData = {};
if (isSet(data.userEmail))     userData.email      = toLowerCase(data.userEmail);
if (isSet(data.userPhone))     userData.phone      = data.userPhone;
if (isSet(data.userFirstName)) userData.first_name = toLowerCase(data.userFirstName);
if (isSet(data.userLastName))  userData.last_name  = toLowerCase(data.userLastName);
if (isSet(data.userCity))      userData.city       = toLowerCase(data.userCity);
if (isSet(data.userState))     userData.state      = toLowerCase(data.userState);
if (isSet(data.userPostalCode)) userData.postal_code = data.userPostalCode;
if (isSet(data.userCountry))   userData.country    = toLowerCase(data.userCountry);
if (isSet(data.externalId))    userData.external_id = data.externalId;
if (isSet(fbc))                userData.fbc        = fbc;
if (isSet(fbp))                userData.fbp        = fbp;

if (Object.keys(userData).length > 0) {
  payload.user_data = userData;
}

// Custom properties
if (data.customProperties && data.customProperties.length > 0) {
  var customMap = makeTableMap(data.customProperties, 'paramName', 'paramValue');
  var customKeys = Object.keys(customMap);
  for (var ci = 0; ci < customKeys.length; ci++) {
    var ck = customKeys[ci];
    if (isSet(ck) && isSet(customMap[ck])) {
      payload[ck] = customMap[ck];
    }
  }
}

// ─── Debug logging ────────────────────────────────────────────────────────────

if (data.enableLogging) {
  log('[MeioDEV Conversion API] Event:', eventName);
  log('[MeioDEV Conversion API] Payload:', JSON.stringify(payload));
}

// ─── Send request ─────────────────────────────────────────────────────────────

var endpoint = data.endpointUrl;

if (data.httpMethod === 'GET') {
  var qs = buildQueryString(payload);
  var separator = endpoint.indexOf('?') === -1 ? '?' : '&';
  sendPixel(endpoint + separator + qs, data.gtmOnSuccess, data.gtmOnFailure);
} else {
  // POST via sendPixel with JSON body appended as query param for compatibility,
  // or use the standard approach: encode body as query string
  // GTM Sandboxed JS does not have a native fetch/XHR for POST,
  // so we send as a GET with all params encoded in the URL.
  // For true POST support, configure a server-side GTM container or use
  // the injectScript approach to call a helper function.
  var qs = buildQueryString(payload);
  var separator = endpoint.indexOf('?') === -1 ? '?' : '&';
  sendPixel(endpoint + separator + qs, data.gtmOnSuccess, data.gtmOnFailure);
}


